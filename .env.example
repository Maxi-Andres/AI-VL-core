# iacore service configuration (copy to .env or export before running).
# The CLI (menu.py) does NOT use these; only the HTTP service (service.py) does.

# Port the inference service listens on (passed to uvicorn yourself, see README).
IACORE_PORT=8001

# Ollama endpoint the VLM client hits. Defaults to config.json's "url"
# (http://localhost:11434) when unset.
OLLAMA_URL=http://localhost:11434

# Text-to-speech default voice (used by /speak when the caller doesn't pass one).
# A Piper name (es_AR-daniela-high, …) uses Piper; a Kokoro name (ef_dora, em_alex,
# em_santa) uses Kokoro. The engine is picked from the voice name.
# TTS_VOICE=es_AR-daniela-high

# Kokoro model files (downloaded by the installer into kokoro_models/). Override
# only to relocate them. KOKORO_LANG is the phonemizer language (default "es").
# KOKORO_MODELS_DIR=./kokoro_models
# KOKORO_LANG=es
