# iacore service configuration (copy to .env or export before running).
# The CLI (menu.py) does NOT use these; only the HTTP service (service.py) does.

# Port the inference service listens on (passed to uvicorn yourself, see README).
IACORE_PORT=8001

# Ollama endpoint the VLM client hits. Defaults to config.json's "url"
# (http://localhost:11434) when unset.
OLLAMA_URL=http://localhost:11434
